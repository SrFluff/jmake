#!/bin/sh

COMPILER="CC"
CFLAGS="-O3 -march=native"

while [ $# -gt 0 ]; do
	case "$1" in
		--compiler=*)
			COMPILER="${1#*=}"
			;;
		--cflags=*)
			CFLAGS="${1#*=}"
			;;
		--help)
			echo "Usage: ./configure [flag(s)]"
			echo "flags:"
			echo "--compiler=<compiler>"
			echo "--cflags=<cflags>"
			echo "--help"
			exit 0
			;;
	esac
	shift
done

mkdir -p "bin/"

echo "Checking for C compiler..."

if ! $(which "$COMPILER" > /dev/null 2>&1); then
	echo "'$COMPILER' could not be found."
	exit 1
fi

echo "Checking if C compiler works..."

if ! $(cc -o "bin/test" "src/test.c" > /dev/null 2>&1); then
	echo "Compiler failed to compile test."
	exit 1
fi

echo "Checking if test binary works..."

if ! $(bin/"test"); then
	echo "Test binary failed to run."
	rm "bin/test"
	exit 1
fi

rm "bin/test"

echo "Checking if cJSON is installed..."

if ! $(cc -lcjson -o "bin/cjson_test" "src/cjson_test.c" > /dev/null 2>&1); then
	echo "Compiler failed to compile cJSON test."
	exit 1
fi

rm "bin/cjson_test"

echo "Generating src/buildinfo.h..."
echo "#define PLATFORM \"$(uname)\"" > src/buildinfo.h
echo "#define COMPILER \"$COMPILER\"" >> src/buildinfo.h
echo "Generating Makefile..."
sed -e "s|@CC@|$COMPILER|g" \
	-e "s|@CFLAGS@|$CFLAGS|g" \
	Makefile.in > Makefile

echo "Tests passed, run 'make' to compile Jmake!"
